# ─────────────────────────────────────────────────────────────────────────
# URL base del sitio (SEO: canonicals, Open Graph, JSON-LD, sitemap, robots).
# Es la ÚNICA fuente del dominio en todo el proyecto — ver lib/site.ts.
#
# Producción: definir en Vercel → Settings → Environment Variables (Production)
# como exactamente:  NEXT_PUBLIC_SITE_URL=https://pimenton.io
#
# Al conectar el dominio definitivo la semana próxima, basta con confirmar
# que esta variable apunte a https://pimenton.io. Si no está definida, el
# código cae por defecto a https://pimenton.io (lib/site.ts), así que el SEO
# ya queda correcto desde hoy aunque la web corra en *.vercel.app.
#
# Sin barra final.
# ─────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://pimenton.io
